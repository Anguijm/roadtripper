# dependencies
node_modules/
/.pnp
.pnp.*

# next.js
/.next/
/out/

# production
/build

# env files
.env*.local

# debug
npm-debug.log*

# misc
.DS_Store
*.tsbuildinfo

# harness logs
.harness/logs/

# harness circuit breaker (local-only trigger file; never commit)
.harness_halt

